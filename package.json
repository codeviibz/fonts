{
  "name": "fonts",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm -w @fonts/app run dev",
    "dev:mvp": "npm -w @fonts/mvp run dev",
    "dev:worker": "npm -w @fonts/worker run dev",
    "typecheck": "npm -w @fonts/app run typecheck && npm -w @fonts/worker run typecheck",
    "typecheck:mvp": "npm -w @fonts/mvp run typecheck",
    "test:mvp": "npm -w @fonts/mvp run test",
    "mvp:migrate": "npm -w @fonts/mvp run migrate",
    "mvp:seed": "npm -w @fonts/mvp run seed",
    "mvp:setup": "npm -w @fonts/mvp run setup"
  },
  "devDependencies": {
    "sass": "^1.97.3"
  }
}
